{
  "version": 2,
  "name": "axotbot",

  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^(?!/api).*$",
      "dest": "/public/index.html"
    }
  ],

  "env": {
    "NODE_ENV": "production"
  }
}
